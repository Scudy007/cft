// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Status {
  OPEN
  IN_PROGRESS 
  RESOLVED
  CLOSED
}

enum Role {
  L1
  L2
  L3
  ADMIN
}

enum Criticality {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model User {
  id             String     @id @default(cuid()) 
  name           String?    
  email          String?    @unique
  password       String
  role           Role       @default(L1)

  assignedIssues Issue[]    @relation("AssignedIssues")
  comments       Comment[]
  logs           AuditLog[]
}

model Issue {
  id               Int          @id @default(autoincrement())
  title            String       @db.VarChar(255)  
  system           String       @db.VarChar(255) 
  category         String       @db.VarChar(255)  
  description      String       @db.Text 
  status           Status       @default(OPEN)
  criticality      Criticality  @default(MEDIUM)
  riskScore        Float?
  discoveryDate    DateTime     @default(now())
  deadline         DateTime?
  assignedToUserId String?
  assignedToUser   User?        @relation("AssignedIssues", fields: [assignedToUserId], references: [id])
  comments         Comment[]    
  history          AuditLog[]   
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  cvssScore        Float?   @default(0)
  dreadScore       Float?   @default(0)
  cvssVector       String?

  cvssAV           AttackVector?       @default(NETWORK)
  cvssAC           AttackComplexity?   @default(LOW)
  cvssPR           PrivilegesRequired? @default(NONE)
  cvssUI           UserInteraction?    @default(NONE)
  cvssS            Scope?              @default(UNCHANGED)
  cvssC            CIA?                @default(NONE)
  cvssI            CIA?                @default(NONE)
  cvssA            CIA?                @default(NONE)

  dreadDamage      Int @default(1)
  dreadRepro       Int @default(1)
  dreadExploit     Int @default(1)
  dreadAffected    Int @default(1)
  dreadDiscover    Int @default(1)
}

model Comment {
  id        Int      @id @default(autoincrement())
  text      String   @db.Text
  issueId   Int
  issue     Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  createdAt DateTime @default(now())
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  issueId   Int
  issue     Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String 
  oldValue  String?
  newValue  String? 
  comment   String?
  createdAt DateTime @default(now())
}

enum AttackVector {
  NETWORK
  ADJACENT
  LOCAL
  PHYSICAL
}

enum AttackComplexity {
  LOW
  HIGH
}

enum PrivilegesRequired {
  NONE
  LOW
  HIGH
}

enum UserInteraction {
  NONE
  REQUIRED
}

enum Scope {
  UNCHANGED
  CHANGED
}

enum CIA {
  NONE
  LOW
  HIGH
}